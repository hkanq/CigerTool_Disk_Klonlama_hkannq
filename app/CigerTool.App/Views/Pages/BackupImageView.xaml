<UserControl x:Class="CigerTool.App.Views.Pages.BackupImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18">
      <Border Style="{StaticResource CardBorderStyle}" Background="#F4FBF8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="{Binding Snapshot.Heading}" />
            <TextBlock Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="{Binding Snapshot.Summary}" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding StatusMessage}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Width="120"
                  Height="42"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshCommand}"
                  Content="Yenile"
                  Style="{StaticResource SecondaryActionButtonStyle}" />
        </Grid>
      </Border>

      <ItemsControl ItemsSource="{Binding Snapshot.Metrics}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="270" Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding Label}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Value}" />
                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding SupportingText}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="İşlem ayarları" />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
              <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="İşlem türü" />
              <ComboBox Margin="0,8,0,0"
                        ItemsSource="{Binding Snapshot.Operations}"
                        SelectedItem="{Binding SelectedOperation}"
                        DisplayMemberPath="Title" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding SelectedOperation.Description}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="0,0,12,0"
                        Visibility="{Binding ShowFormatSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="İmaj biçimi" />
              <ComboBox Margin="0,8,0,0"
                        ItemsSource="{Binding Formats}"
                        SelectedItem="{Binding SelectedFormat}"
                        DisplayMemberPath="Title" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding SelectedFormat.Description}" />
            </StackPanel>
          </Grid>

          <StackPanel Margin="0,16,0,0"
                      Visibility="{Binding ShowCaptureModeSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="İmaj yöntemi" />
            <ComboBox Margin="0,8,0,0"
                      ItemsSource="{Binding CaptureModes}"
                      SelectedItem="{Binding SelectedCaptureMode}"
                      DisplayMemberPath="Title" />
            <TextBlock Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding SelectedCaptureMode.Description}" />
            <Border Margin="0,10,0,0"
                    Padding="12"
                    CornerRadius="14"
                    Background="#F8F5EA">
              <TextBlock TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="Akıllı imaj alma şu anda sistem dışı sürücüler için açıktır ve yalnızca kullanılan dosyaları kaydeder." />
            </Border>
          </StackPanel>

          <StackPanel Margin="0,16,0,0"
                      Visibility="{Binding ShowSourceDiskSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kaynak sürücü" />
            <ComboBox Margin="0,8,0,0"
                      ItemsSource="{Binding Snapshot.CandidateDisks}"
                      SelectedItem="{Binding SelectedSource}"
                      DisplayMemberPath="Name" />
            <TextBlock Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding SelectedSource.IdentityLabel, TargetNullValue=Kaynak sürücü seçilmedi.}" />
          </StackPanel>

          <StackPanel Margin="0,16,0,0"
                      Visibility="{Binding ShowTargetDiskSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Hedef sürücü" />
            <ComboBox Margin="0,8,0,0"
                      ItemsSource="{Binding Snapshot.CandidateDisks}"
                      SelectedItem="{Binding SelectedTarget}"
                      DisplayMemberPath="Name" />
            <TextBlock Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding SelectedTarget.WarningSummary, TargetNullValue=Hedef sürücü seçilmedi.}" />
          </StackPanel>

          <StackPanel Margin="0,16,0,0"
                      Visibility="{Binding ShowSourceImageSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kaynak imaj dosyası" />
            <DockPanel Margin="0,8,0,0">
              <Button Width="140"
                      Height="40"
                      DockPanel.Dock="Right"
                      Margin="12,0,0,0"
                      Command="{Binding BrowseSourceImageCommand}"
                      Content="Dosya seç"
                      Style="{StaticResource SecondaryActionButtonStyle}" />
              <Button Width="100"
                      Height="40"
                      DockPanel.Dock="Right"
                      Margin="12,0,0,0"
                      Command="{Binding ClearSourceImageCommand}"
                      Content="Temizle"
                      Style="{StaticResource SecondaryActionButtonStyle}" />
              <TextBox MinHeight="40"
                       VerticalContentAlignment="Center"
                       IsReadOnly="True"
                       Text="{Binding SourceImagePath, TargetNullValue=Henüz dosya seçilmedi.}" />
            </DockPanel>
          </StackPanel>

          <StackPanel Margin="0,16,0,0"
                      Visibility="{Binding ShowDestinationSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kayıt yolu" />
            <DockPanel Margin="0,8,0,0">
              <Button Width="140"
                      Height="40"
                      DockPanel.Dock="Right"
                      Margin="12,0,0,0"
                      Command="{Binding BrowseDestinationCommand}"
                      Content="Yol seç"
                      Style="{StaticResource SecondaryActionButtonStyle}" />
              <Button Width="100"
                      Height="40"
                      DockPanel.Dock="Right"
                      Margin="12,0,0,0"
                      Command="{Binding ClearDestinationCommand}"
                      Content="Temizle"
                      Style="{StaticResource SecondaryActionButtonStyle}" />
              <TextBox MinHeight="40"
                       VerticalContentAlignment="Center"
                       IsReadOnly="True"
                       Text="{Binding DestinationPath, TargetNullValue=Henüz kayıt yolu seçilmedi.}" />
            </DockPanel>
          </StackPanel>

          <CheckBox Margin="0,16,0,0"
                    IsChecked="{Binding ConfirmDestructiveRestore}"
                    Visibility="{Binding IsDestructiveOperation, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Content="Hedef sürücünün üzerine yazılacağını anlıyorum." />

          <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
            <Button Width="180"
                    Height="44"
                    Command="{Binding AnalyzeCommand}"
                    Content="Denetimi çalıştır"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
            <Button Width="160"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding StartOperationCommand}"
                    Content="İşlemi başlat"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
            <Button Width="120"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding CancelOperationCommand}"
                    Content="İptal et"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFB">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Denetim sonucu" />
          <TextBlock Margin="0,12,0,0"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding Plan.StatusLabel, TargetNullValue=Henüz doğrulanmadı}" />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Plan.Summary, TargetNullValue='İşlem türünü seçip gerekli alanları doldurduktan sonra özet burada görünür.'}" />

          <TextBlock Margin="0,12,0,0"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Sonraki adım" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Plan.NextAction, TargetNullValue=Doğrulama sonucu burada bir sonraki adımı gösterecek.}" />

          <TextBlock Margin="0,12,0,0"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Kapsam notu" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding Plan.ScopeNote, TargetNullValue='Bu bölüm desteklenen gerçek kapsamı açıkça gösterir.'}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Çalışan işlem" />
          <TextBlock Margin="0,12,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding ProgressSummary}" />
          <ProgressBar Margin="0,12,0,0"
                       Height="14"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding ProgressPercent, Mode=OneWay}" />
          <TextBlock Margin="0,10,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding ProgressDetail}" />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding CurrentProgress.CurrentItem, TargetNullValue=Şu an işlenen öğe burada görünür.}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Adım adım akış" />
          <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding PlanSteps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,10"
                        Padding="14"
                        CornerRadius="16"
                        Background="#F7FAFB"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1">
                  <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding Title}" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ContentTextBrush}"
                               Text="{Binding Description}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Uyarılar" />
          <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding PlanWarnings}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFB">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="İşlem sonucu" />
          <TextBlock Margin="0,12,0,0"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding LastExecution.StatusLabel, TargetNullValue=Henüz işlem sonucu yok}" />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding LastExecution.Summary, TargetNullValue='İşlem tamamlandığında bu bölümde özet görünür.'}" />
          <TextBlock Margin="0,8,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding LastExecution.FormatLabel, TargetNullValue=Seçilen biçim burada görünür.}" />

          <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ExecutionWarnings}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
            <Button Width="220"
                    Height="44"
                    Command="{Binding SavePlanCommand}"
                    Content="Denetim raporunu kaydet"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
            <Button Width="220"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding SaveExecutionReportCommand}"
                    Content="Sonuç raporunu kaydet"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Desteklenen senaryolar" />
          <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Snapshot.SupportedScenarios}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
