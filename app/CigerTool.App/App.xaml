<Application x:Class="CigerTool.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CigerTool.App.Converters"
             xmlns:pages="clr-namespace:CigerTool.App.Views.Pages"
             xmlns:viewModels="clr-namespace:CigerTool.App.ViewModels.Pages">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Styles/Colors.xaml" />
        <ResourceDictionary Source="Styles/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <converters:BooleanToFriendlyTextConverter x:Key="BooleanToFriendlyTextConverter" />
      <converters:OperationSeverityToFriendlyTextConverter x:Key="OperationSeverityToFriendlyTextConverter" />
      <converters:CloneSuitabilityStatusToFriendlyTextConverter x:Key="CloneSuitabilityStatusToFriendlyTextConverter" />
      <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

      <DataTemplate DataType="{x:Type viewModels:DashboardPageViewModel}">
        <pages:DashboardView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:CloningPageViewModel}">
        <pages:CloningView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:BackupImagePageViewModel}">
        <pages:BackupImageView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:DisksPageViewModel}">
        <pages:DisksView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:UsbCreatorPageViewModel}">
        <pages:UsbCreatorView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:LogsPageViewModel}">
        <pages:LogsView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
        <pages:SettingsView />
      </DataTemplate>
    </ResourceDictionary>
  </Application.Resources>
</Application>
